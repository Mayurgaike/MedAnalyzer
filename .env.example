# Medical Report Analyzer — Environment Configuration
# Copy this file to .env and fill in your values

# ---- Google Gemini API (FREE — get key at https://aistudio.google.com/apikey) ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Gemini Model ----
GEMINI_MODEL=gemini-2.0-flash

# ---- Database ----
DATABASE_URL=sqlite:///./medical_analyzer.db

# ---- Encryption Key (auto-generated if not set) ----
# ENCRYPTION_KEY=your_random_key_here

# ---- Server ----
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ---- NER Model ----
NER_MODEL_NAME=d4data/biomedical-ner-all
NER_CACHE_DIR=./model_cache

# ---- OCR Engine (surya | paddle | pdfplumber) ----
OCR_ENGINE=surya

# ---- File Upload ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
