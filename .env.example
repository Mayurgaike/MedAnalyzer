# Medical Report Analyzer — Environment Configuration
# Copy this file to .env and fill in your values

# ---- Claude API (required for AI summaries, optional for demo mode) ----
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- Claude Model ----
# Verify at console.anthropic.com before demo day
CLAUDE_MODEL=claude-opus-4-5

# ---- Database ----
DATABASE_URL=sqlite:///./medical_analyzer.db

# ---- Encryption Key (auto-generated if not set) ----
# ENCRYPTION_KEY=your_random_key_here

# ---- Server ----
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ---- NER Model ----
NER_MODEL_NAME=d4data/biomedical-ner-all
NER_CACHE_DIR=./model_cache

# ---- OCR Engine (surya | paddle | pdfplumber) ----
OCR_ENGINE=surya

# ---- File Upload ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
